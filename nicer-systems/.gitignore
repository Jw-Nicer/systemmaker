# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Firebase
firebase-debug.log
/.firebase/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
users.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# gcloud sandbox state (contains access_tokens.db, credentials.db — MUST NOT be committed)
.gcloud-tmp/

# dev server + test run scratch output
tmp/
tmp-devserver.out.log
tmp-devserver.err.log
