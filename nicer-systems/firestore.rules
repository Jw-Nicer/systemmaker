rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Site settings — public read, admin write
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Case studies — public read if published, admin full access
    match /case_studies/{docId} {
      allow read: if resource.data.status == "published";
      allow read, write: if request.auth != null;
    }

    // Testimonials — public read if published, admin full access
    match /testimonials/{docId} {
      allow read: if resource.data.is_published == true;
      allow read, write: if request.auth != null;
    }

    // Offers — public read if published, admin full access
    match /offers/{docId} {
      allow read: if resource.data.is_published == true;
      allow read, write: if request.auth != null;
    }

    // FAQs — public read if published, admin full access
    match /faqs/{docId} {
      allow read: if resource.data.is_published == true;
      allow read, write: if request.auth != null;
    }

    // Leads — public can create (restricted fields), admin can read/update
    match /leads/{docId} {
      allow create: if true
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'company', 'bottleneck', 'tools', 'urgency',
          'status', 'source', 'industry', 'score', 'created_at',
          'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'landing_path'
        ]);
      allow read, update, delete: if request.auth != null;

      // Activity timeline — admin only
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
    }

    // Events — public can create (restricted fields), admin can read
    match /events/{docId} {
      allow create: if true
        && request.resource.data.keys().hasOnly([
          'event_name', 'payload', 'lead_id', 'created_at'
        ]);
      allow read: if request.auth != null;
    }

    // Agent templates — admin only
    match /agent_templates/{docId} {
      allow read, write: if request.auth != null;
    }

    // Industry probing — admin only (read by server via Admin SDK,
    // never directly from the client)
    match /industry_probing/{docId} {
      allow read, write: if request.auth != null;
    }

    // Experiments — public read if running (for client bucketing), admin full access
    match /experiments/{docId} {
      allow read: if resource.data.status == "running";
      allow read, write: if request.auth != null;
    }

    // Landing variants — public read if published, admin full access
    match /variants/{docId} {
      allow read: if resource.data.is_published == true;
      allow read, write: if request.auth != null;
    }

    // Plans — public read if is_public, server-side create, admin full access
    match /plans/{docId} {
      allow read: if resource.data.is_public == true;
      allow read, write: if request.auth != null;
    }

    // Agent memory — server-only (Admin SDK bypasses rules).
    // Explicit deny prevents accidental client-side access to visitor data.
    match /agent_memory/{docId} {
      allow read, write: if request.auth != null;
    }

    // Pipeline traces — server-only (fire-and-forget writes from runner).
    // Admin can read for debugging; no client access.
    match /pipeline_traces/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}