{
  "name": "nicer-systems",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/fix-turbopack-externals.js",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "node scripts/typecheck.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "firebase deploy",
